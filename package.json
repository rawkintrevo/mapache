{
  "name": "mapache-tools",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "vite",
    "docs:check": "node scripts/check-doc-links.js",
    "test:frontend": "vitest run",
    "build:main": "vite build",
    "build:community": "cd community && npm run build",
    "move:community": "mkdir -p dist/community && cp -r community/build/* dist/community/",
    "build": "npm run build:main && npm run build:community && npm run move:community",
    "check": "npm run docs:check && npm --prefix functions test && npm --prefix session-runner run lint && npm run test:frontend && npm run build",
    "preview": "vite preview"
  },
  "dependencies": {
    "firebase": "^12.14.0",
    "lucide-react": "^1.18.0",
    "react": "^19.2.7",
    "react-dom": "^19.2.7",
    "vite": "^8.0.16"
  },
  "devDependencies": {
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@testing-library/user-event": "^14.6.1",
    "@vitejs/plugin-react": "^6.0.2",
    "jsdom": "^29.1.1",
    "vitest": "^4.1.9"
  }
}

{
  "id": "script.createPiSkill",
  "title": "Create a workspace-local skill",
  "parameters": {
    "skillName": "qa-skill-{{timestamp}}",
    "description": "Use when validating QA skill creation.",
    "content": "# QA Skill\n\nValidate skill creation from the web UI."
  },
  "actions": [
    {"useScript": "scripts/expand-inspector.json"},
    {"type": "fill", "label": "Skill name", "value": "{{skillName}}"},
    {"type": "fill", "label": "Description", "value": "{{description}}"},
    {"type": "fill", "label": "Markdown instructions", "value": "{{content}}"},
    {"type": "click", "role": "button", "name": "Create skill"},
    {"type": "waitForNetwork", "requestUrlIncludes": "/skills", "method": "POST", "expectedStatus": 200, "timeoutMs": 10000}
  ],
  "successSignals": [
    "POST /skills returns 200",
    "Skills panel lists the created skill"
  ],
  "requires": {
    "session": "Selected active session"
  }
}

{
  "id": "skills.crud",
  "title": "Workspace-local Pi skills CRUD",
  "description": "Create a session, create a Pi skill, edit it, delete it, and clean up.",
  "baseUrl": "http://127.0.0.1:5173",
  "artifactsDir": "artifacts/qa/skills.crud",
  "requires": {
    "cloudRun": "Creates a billable Cloud Run service"
  },
  "steps": [
    {"useCase": "cases/login.json"},
    {"useScript": "scripts/create-blank-workspace.json", "parameters": {"workspaceName": "qa-skills-ws-{{timestamp}}"}},
    {"useScript": "scripts/create-session.json", "parameters": {"sessionName": "qa-skills-session-{{timestamp}}", "imageKey": "pi-basic"}},
    {"useScript": "scripts/create-pi-skill.json", "parameters": {"skillName": "qa-skill-{{timestamp}}"}},
    {"useScript": "scripts/edit-pi-skill.json", "parameters": {"skillName": "qa-skill"}},
    {"useScript": "scripts/delete-pi-skill.json", "parameters": {"skillName": "qa-skill"}},
    {"useScript": "scripts/delete-selected-session.json"},
    {"useScript": "scripts/delete-selected-workspace.json"}
  ]
}

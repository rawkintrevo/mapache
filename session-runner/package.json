{
  "name": "mapache-tools-session-runner",
  "version": "0.1.0",
  "private": true,
  "description": "Cloud Run terminal runner for Mapache Tools sessions.",
  "main": "server.js",
  "scripts": {
    "lint": "find . -path ./node_modules -prune -o -name '*.js' -type f -print0 | xargs -0 -n1 node --check",
    "test": "node --test lib/*.test.js",
    "start": "node server.js"
  },
  "dependencies": {
    "@google-cloud/storage": "^7.17.3",
    "@xterm/addon-fit": "^0.11.0",
    "@xterm/xterm": "^6.0.0",
    "express": "^4.21.2",
    "firebase-admin": "^13.6.0",
    "node-pty": "^1.0.0",
    "ws": "^8.18.3"
  },
  "engines": {
    "node": "24"
  }
}
